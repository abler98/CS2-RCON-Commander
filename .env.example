# Server Configuration
SERVER_IP=
SERVER_PORT=27015
RCON_PASSWORD=

# Debug & Development
DEBUG=false

# CS2 HTTP Log Ingestion (logaddress_add_http)
# Secret used to HMAC-SHA256 the server address. Required to enable log
# ingestion and streaming; when empty, both endpoints are disabled.
LOG_INGEST_SECRET=
# Max log lines kept in memory per server (ring buffer).
LOG_MAX_LINES_PER_SERVER=1000
# Max distinct server addresses retained in memory.
LOG_MAX_SERVERS=50
